import type { MetadataRoute } from 'next';
import { ListingStatus } from '@prisma/client';
import { prisma } from '@/lib/server/prisma';

const SITE_URL = process.env.NEXT_PUBLIC_APP_URL?.replace(/\/+$/, '') || 'https://vin2win.ru';
const STATIC_ROUTES = ['/', '/wanted'] as const;

export const revalidate = 3600;

function toAbsoluteUrl(path: string): string {
  return `${SITE_URL}${path}`;
}

export default async function sitemap(): Promise<MetadataRoute.Sitemap> {
  const now = new Date();
  const [saleListings, wantedListings] = await Promise.all([
    prisma.saleListing.findMany({
      where: {
        status: ListingStatus.PUBLISHED,
      },
      select: {
        id: true,
        updatedAt: true,
      },
      orderBy: {
        updatedAt: 'desc',
      },
    }),
    prisma.wantedListing.findMany({
      where: {
        status: ListingStatus.PUBLISHED,
      },
      select: {
        id: true,
        updatedAt: true,
      },
      orderBy: {
        updatedAt: 'desc',
      },
    }),
  ]);

  return [
    ...STATIC_ROUTES.map((path) => ({
      url: toAbsoluteUrl(path),
      lastModified: now,
      changeFrequency: 'daily' as const,
      priority: path === '/' ? 1 : 0.8,
    })),
    ...saleListings.map((listing) => ({
      url: toAbsoluteUrl(`/listing/${listing.id}`),
      lastModified: listing.updatedAt,
      changeFrequency: 'daily' as const,
      priority: 0.9,
    })),
    ...wantedListings.map((listing) => ({
      url: toAbsoluteUrl(`/wanted/${listing.id}`),
      lastModified: listing.updatedAt,
      changeFrequency: 'daily' as const,
      priority: 0.7,
    })),
  ];
}
