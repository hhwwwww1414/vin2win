'use client';

import Link from 'next/link';
import { AlertTriangle, ArrowUpRight, Camera, CheckCircle, Clock3, Eye, MapPin } from 'lucide-react';
import type { SaleListing } from '@/lib/types';
import { formatMileage, formatPrice } from '@/lib/marketplace-data';
import { getListingAgeLabel, getListingBadges, getListingTitle } from '@/lib/listing-utils';
import { cn } from '@/lib/utils';
import { CompareToggle } from './compare-toggle';
import { FavoriteToggle } from './favorite-toggle';
import { ListingChipsBlock } from './listing-chips-block';
import { ListingImageCarousel } from './listing-image-carousel';
import { ListingStatusBlock } from './listing-status-block';

interface ListingCardViewProps {
  listing: SaleListing;
  priority?: boolean;
  isAuthenticated?: boolean;
  loginHref?: string;
  className?: string;
}

function getPaintCountLabel(count: number) {
  if (count === 0) {
    return 'Без окрасов';
  }

  const mod100 = count % 100;
  const mod10 = count % 10;

  if (mod100 >= 11 && mod100 <= 14) {
    return `${count} окрасов`;
  }

  if (mod10 === 1) {
    return `${count} окрас`;
  }

  if (mod10 >= 2 && mod10 <= 4) {
    return `${count} окраса`;
  }

  return `${count} окрасов`;
}

export function ListingCardView({
  listing,
  priority = false,
  isAuthenticated = false,
  loginHref,
  className,
}: ListingCardViewProps) {
  const title = getListingTitle(listing);
  const badges = getListingBadges(listing);
  const paintLabel = getPaintCountLabel(listing.paintCount);
  const resourceBadge =
    listing.resourceStatus === 'on_resources'
      ? {
          label: 'На ресурсах',
          className: 'bg-teal-accent/95 text-[#09090B]',
        }
      : listing.resourceStatus === 'pre_resources'
        ? {
            label: 'До ресурсов',
            className: 'bg-warning/90 text-[#09090B]',
          }
        : null;

  const detailPills = [listing.color, listing.drive, `${listing.power} л.с.`];
  const stats = [
    { label: 'Пробег', value: formatMileage(listing.mileage) },
    { label: 'Техника', value: `${listing.engine} / ${listing.transmission}` },
    { label: 'Владельцы', value: `${listing.owners} хоз` },
    { label: 'Кузов', value: paintLabel, tone: listing.paintCount === 0 ? 'text-success' : 'text-warning' },
  ];
  const hasRiskSignals = listing.avtotekaStatus === 'green' || listing.accident;

  return (
    <Link
      href={`/listing/${listing.id}`}
      className={cn(
        'group card-interactive relative block overflow-hidden rounded-[28px] border border-border/70 bg-card/95 shadow-[0_12px_34px_rgba(15,23,42,0.06)] backdrop-blur-sm transition-all duration-200',
        'hover:-translate-y-0.5 hover:border-teal-accent/35 hover:shadow-[0_22px_54px_rgba(15,23,42,0.14)]',
        'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-accent/60 focus-visible:ring-offset-2 focus-visible:ring-offset-background',
        'dark:bg-surface-elevated/90',
        className
      )}
    >
      <span
        aria-hidden="true"
        className="card-press-carbon pointer-events-none absolute inset-0 z-[1] rounded-[inherit] opacity-0 transition-opacity duration-[180ms] ease-out"
      />
      <span
        aria-hidden="true"
        className="pointer-events-none absolute inset-x-0 top-0 z-[1] h-px bg-gradient-to-r from-transparent via-teal-accent/60 to-transparent"
      />

      <div className="relative z-[2] flex min-h-0 flex-col sm:flex-row sm:items-stretch">
        <div className="relative aspect-[16/10] w-full border-b border-border/50 sm:w-[240px] sm:flex-shrink-0 sm:border-b-0 sm:border-r sm:aspect-auto lg:w-[280px]">
          <ListingImageCarousel
            images={listing.images}
            alt={title}
            size="card"
            priority={priority}
            className="h-full w-full rounded-t-[28px] sm:rounded-l-[28px] sm:rounded-tr-none"
          />

          <div className="absolute left-3 top-3 z-10 flex flex-wrap items-center gap-2">
            {resourceBadge ? (
              <span className={cn('rounded-full px-2.5 py-1 text-[10px] font-semibold shadow-sm', resourceBadge.className)}>
                {resourceBadge.label}
              </span>
            ) : null}
          </div>

          <div className="absolute right-3 top-3 z-10 flex items-center gap-2">
            <CompareToggle listingId={listing.id} />
            <FavoriteToggle
              listingId={listing.id}
              initialActive={listing.isFavorite}
              isAuthenticated={isAuthenticated}
              loginHref={loginHref}
            />
          </div>

          <div className="absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-black/65 via-black/15 to-transparent px-3 pb-3 pt-8">
            <div className="flex items-center justify-between gap-2 text-white">
              <span className="inline-flex items-center gap-1 rounded-full bg-black/35 px-2.5 py-1 text-[11px] font-medium backdrop-blur">
                <Camera className="h-3.5 w-3.5" />
                {listing.images.length} фото
              </span>
              <span className="rounded-full bg-black/35 px-2.5 py-1 text-[11px] font-medium backdrop-blur">
                {listing.bodyType}
              </span>
            </div>
          </div>
        </div>

        <div className="flex min-w-0 flex-1 flex-col p-4 sm:p-5 lg:p-6">
          <div className="flex flex-wrap items-center gap-2 text-[11px] font-medium uppercase tracking-[0.12em] text-muted-foreground">
            <span className="inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-background/70 px-2.5 py-1 dark:bg-background/10">
              <MapPin className="h-3.5 w-3.5 shrink-0 opacity-70" />
              {listing.city}
            </span>
            <span className="inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-background/70 px-2.5 py-1 dark:bg-background/10">
              <Clock3 className="h-3.5 w-3.5 shrink-0 opacity-70" />
              {getListingAgeLabel(listing)}
            </span>
            <span className="inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-background/70 px-2.5 py-1 dark:bg-background/10">
              <Eye className="h-3.5 w-3.5 shrink-0 opacity-70" />
              {listing.viewCount.toLocaleString('ru-RU')}
            </span>
          </div>

          <div className="mt-3 flex items-start justify-between gap-3">
            <div className="min-w-0">
              <h3 className="font-display text-lg font-semibold leading-tight text-foreground sm:text-[1.2rem]">
                {title}
              </h3>

              <div className="mt-2 flex flex-wrap gap-1.5 text-[11px] text-muted-foreground">
                {detailPills.map((item) => (
                  <span
                    key={item}
                    className="rounded-full border border-border/60 bg-background/65 px-2.5 py-1 dark:bg-background/10"
                  >
                    {item}
                  </span>
                ))}
              </div>
            </div>

            <span className="hidden items-center gap-1 rounded-full border border-teal-accent/20 bg-teal-accent/10 px-3 py-1.5 text-[11px] font-semibold text-teal-accent dark:bg-teal-accent/12 lg:inline-flex">
              Открыть
              <ArrowUpRight className="h-3.5 w-3.5" />
            </span>
          </div>

          <div className="mt-4 flex flex-wrap items-end gap-2.5">
            <span className="font-display text-2xl font-bold tracking-tight text-foreground tabular-nums">
              {formatPrice(listing.price)}
            </span>
            {listing.priceInHand ? (
              <span className="rounded-full border border-success/20 bg-success/10 px-2.5 py-1 text-xs font-medium text-success tabular-nums">
                В руки {formatPrice(listing.priceInHand)}
              </span>
            ) : null}
          </div>

          <div className="mt-4 rounded-[24px] border border-border/60 bg-gradient-to-br from-background/85 to-background/60 p-3.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.4)] dark:from-background/10 dark:to-background/[0.04] dark:shadow-none">
            {hasRiskSignals ? (
              <div className="flex flex-wrap items-center gap-2">
                {listing.avtotekaStatus === 'green' ? (
                  <span className="inline-flex items-center gap-1.5 rounded-full border border-success/20 bg-success/10 px-2.5 py-1 text-xs font-medium text-success">
                    <CheckCircle className="h-3.5 w-3.5" />
                    Автотека
                  </span>
                ) : null}
                {listing.accident ? (
                  <span className="inline-flex items-center gap-1.5 rounded-full border border-warning/20 bg-warning/10 px-2.5 py-1 text-xs font-medium text-warning">
                    <AlertTriangle className="h-3.5 w-3.5" />
                    ДТП
                  </span>
                ) : null}
              </div>
            ) : null}

            <div className={cn('grid grid-cols-2 gap-2 lg:grid-cols-4', hasRiskSignals && 'mt-3')}>
              {stats.map((item) => (
                <div
                  key={item.label}
                  className="rounded-2xl border border-border/60 bg-background/70 px-3 py-2.5 dark:bg-background/10"
                >
                  <p className="text-[11px] font-medium uppercase tracking-[0.14em] text-muted-foreground">{item.label}</p>
                  <p className={cn('mt-1 text-sm font-semibold text-foreground', item.tone)}>{item.value}</p>
                </div>
              ))}
            </div>
          </div>

          <ListingChipsBlock chips={badges} variant="card" maxCount={6} className="mt-4" />

          <div className="mt-4 rounded-[22px] border border-border/60 bg-gradient-to-br from-background/80 to-background/55 p-3 dark:from-background/10 dark:to-background/[0.04] sm:hidden">
            <div className="flex items-center justify-between gap-3">
              <div>
                <p className="text-[10px] font-semibold uppercase tracking-[0.16em] text-muted-foreground">Продавец</p>
                <ListingStatusBlock listing={listing} layout="horizontal" size="sm" className="mt-2" />
              </div>
              <span className="inline-flex items-center gap-1 rounded-full border border-teal-accent/20 bg-teal-accent/10 px-3 py-1.5 text-xs font-semibold text-teal-accent">
                Открыть
                <ArrowUpRight className="h-3.5 w-3.5" />
              </span>
            </div>
          </div>
        </div>

        <div className="hidden shrink-0 border-l border-border/50 bg-gradient-to-b from-background/55 to-transparent p-4 sm:flex sm:w-[148px] dark:from-background/10">
          <div className="flex w-full flex-col justify-between rounded-[22px] border border-border/60 bg-gradient-to-br from-background/80 to-background/55 p-3 text-right dark:from-background/10 dark:to-background/[0.04]">
            <div>
              <p className="text-[10px] font-semibold uppercase tracking-[0.16em] text-muted-foreground">Продавец</p>
              <ListingStatusBlock listing={listing} layout="vertical" className="mt-2 items-end" />
            </div>

            <div className="space-y-2.5">
              <div className="rounded-2xl border border-teal-accent/20 bg-teal-accent/10 px-3 py-2.5 text-left">
                <div className="inline-flex items-center justify-between gap-2 text-sm font-semibold text-foreground">
                  <span>Открыть</span>
                  <ArrowUpRight className="h-3.5 w-3.5 text-teal-accent" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Link>
  );
}
