          {canSaveSearch ? (
            <SectionShell>
              <SectionTitle
                eyebrow="Автоматизация"
                title="Сохранить текущий поиск"
                description="Зафиксируйте рабочую комбинацию фильтров и включите уведомления по новым совпадениям."
                icon={<Save className="h-4 w-4" />}
              />

              <div className="grid gap-4 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
                <Field label="Название">
                  <input
                    className={textInputClassName()}
                    value={searchName}
                    onChange={(event) => setSearchName(event.target.value)}
                    placeholder="Например, Camry до 3 млн"
                  />
                </Field>

                <Button
                  type="button"
                  variant="outline"
                  className="h-12 rounded-2xl"
                  disabled={!draftHasFilters || isSavingSearch}
                  onClick={() => onSaveSearch?.({ ...draft, page: 1 }, searchName)}
                >
                  <Save className="mr-2 h-4 w-4" />
                  {isSavingSearch ? 'Сохраняем...' : 'Сохранить поиск'}
                </Button>
              </div>
            </SectionShell>
          ) : null}
        </div>

        <SheetFooter className="sticky bottom-0 z-20 border-t border-border/70 bg-background/88 px-4 py-4 backdrop-blur sm:px-6">
          <div className="flex w-full flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div className="text-sm text-muted-foreground">
              {activeFilterCount > 0 ? `Готово к применению: ${activeFilterCount} фильтров.` : 'Фильтры не выбраны, будет базовая выдача.'}
            </div>

            <div className="flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
              <Button
                type="button"
                variant="ghost"
                className="h-11 rounded-2xl"
                onClick={() => {
                  onReset();
                  onOpenChange(false);
                }}
              >
                <RotateCcw className="mr-2 h-4 w-4" />
                Сбросить
              </Button>
              <Button
                type="button"
                className="h-11 rounded-2xl bg-teal-dark px-5 text-white hover:bg-teal-medium dark:bg-teal-accent dark:text-[#09090B] dark:hover:bg-seafoam"
                onClick={() => {
                  onApply({ ...draft, page: 1 });
                  onOpenChange(false);
                }}
              >
                Применить фильтры
              </Button>
            </div>
          </div>
        </SheetFooter>
      </SheetContent>
    </Sheet>
  );
}
