  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && npm run db:migrate:deploy && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "21st:login": "npx @21st-sdk/cli login",
    "21st:deploy": "npx @21st-sdk/cli deploy",
    "21st:run": "tsx scripts/run-21st-prompt.ts",
    "playwright:install": "npx playwright install chromium",
    "qa:audit": "playwright test",
    "qa:audit:headed": "playwright test --headed",
    "qa:a11y": "playwright test tests/qa/a11y.spec.ts",
    "db:generate": "tsx scripts/run-prisma.ts generate",
    "db:migrate:deploy": "tsx scripts/run-prisma.ts migrate deploy",
    "db:push": "tsx scripts/run-prisma.ts db push",
    "db:push:reset": "tsx scripts/run-prisma.ts db push --force-reset",
    "db:seed:marketplace": "tsx scripts/reset-and-seed-marketplace.ts",
    "db:repair-text": "tsx scripts/repair-corrupted-text.ts",
    "vehicle-catalog:import": "tsx scripts/vehicle-catalog/import.ts",
    "vehicle-catalog:import:dry-run": "tsx scripts/vehicle-catalog/import.ts --dry-run",
    "vehicle-catalog:import:update": "tsx scripts/vehicle-catalog/import.ts",
    "vehicle-catalog:backfill-sale-listings": "tsx scripts/vehicle-catalog/backfill-sale-listings.ts",
    "vehicle-catalog:report": "tsx scripts/vehicle-catalog/report.ts",
    "auth:bootstrap": "tsx scripts/bootstrap-auth.ts",
    "db:reset-and-seed": "npm run db:push:reset && npm run db:seed:marketplace && npm run auth:bootstrap"
  },
