            </div>
          </SectionShell>

          <SectionShell>
            <SectionTitle
              eyebrow="Диапазоны"
              title="Цена, год, пробег и мощность"
              description="Сразу отсекайте неподходящие уровни бюджета и технические рамки, чтобы ниже работать только с релевантной выборкой."
              icon={<Gauge className="h-4 w-4" />}
            />

            <div className="grid gap-4 sm:grid-cols-2">
              <Field label="Год от">
                <input
                  className={textInputClassName()}
                  inputMode="numeric"
                  value={draft.yearFrom ?? ''}
                  onChange={(event) => setDraft((current) => ({ ...current, yearFrom: event.target.value ? Number(event.target.value) : undefined }))}
                  placeholder="2018"
