                  isHeaderCondensed && 'shrink-0 px-2.5 py-1 text-[11px]'
                )}
              >
                {item}
              </span>
            ))}
          </div>
        </SheetHeader>

        <div className="space-y-5 px-4 py-5 sm:px-6">
          <SectionShell>
            <SectionTitle
              eyebrow="Основа поиска"
              title="Марка, модель, город и порядок выдачи"
              description="Соберите базовый контур запроса, от которого уже имеет смысл уточнять диапазоны и историю."
              icon={<Filter className="h-4 w-4" />}
            />

            <div className="grid gap-4 sm:grid-cols-2">
              <Field label="Марка">
                <Combobox
                  options={availableMakes}
                  value={draft.make[0] ?? ''}
                  onChange={(value) => setDraft((current) => ({ ...current, make: value ? [value] : [], model: [] }))}
                  placeholder="Например, Toyota"
                  searchPlaceholder="Найдите марку"
                  emptyLabel="Марка не найдена"
                  customValueLabel="Указать свою марку"
